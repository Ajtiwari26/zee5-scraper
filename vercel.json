{
  "version": 2,
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://zee5-scraper.onrender.com/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://zee5-scraper.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
